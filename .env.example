# ====================================================
# Redis Config
# ====================================================
REDIS_CONTAINER_NAME="redis-server"

REDIS_ADMIN_NAME="redis_admin"
REDIS_ADMIN_PASSWORD="5up3r-53cr37-p455w0rd"
REDIS_USER_NAME="redis_user"
REDIS_USER_PASSWORD="redis_password"

REDIS_DB_INDEX=0
REDIS_BLACKLIST_PREFIX="blacklist"
REDIS_RATE_LIMIT_PREFIX="rl"
REDIS_RATE_LIMIT_MAX_REQUESTS=100
REDIS_RATE_LIMIT_WINDOW_SECONDS=60

REDIS_HOST="127.0.0.1"
# ====================================================
# Redis Port Configuration:
#   - REDIS_INTERNAL_PORT: Internal port used within Docker network 
#                          for container-to-container communication
#   - REDIS_EXTERNAL_PORT: External port exposed to host machine for 
#                          direct Redis access from outside Docker
# ====================================================
REDIS_INTERNAL_PORT=6379
REDIS_EXTERNAL_PORT=6379


# ====================================================
# PostgreSQL Config
# ====================================================
POSTGRES_CONTAINER_NAME="postgres-server"

POSTGRES_SUPERUSER_NAME="postgres"
POSTGRES_SUPERUSER_PASSWORD="5up3r-53cr37-p455w0rd"
POSTGRES_SYSTEM_DB_NAME="postgres"

POSTGRES_USER_NAME="postgres_user"
POSTGRES_USER_PASSWORD="postgres_password"
POSTGRES_USER_DB_NAME="user_db"

POSTGRES_ECHO=False
POSTGRES_AUTOCOMMIT=False
POSTGRES_AUTOFLUSH=False

POSTGRES_HOST="127.0.0.1"
# ====================================================
# Port Configuration:
#   - POSTGRES_INTERNAL_PORT: Internal port used within Docker network 
#                             for container-to-container communication
#   - POSTGRES_EXTERNAL_PORT: External port exposed to host machine for 
#                             direct PostgreSQL access from outside Docker
# ====================================================
POSTGRES_INTERNAL_PORT=5432
POSTGRES_EXTERNAL_PORT=5432


# ====================================================
# Authentication Config
# ====================================================
AUTHENTICATION_JWT_SECRET_KEY="5up3r-53cr37-jwt-k3y-f0r-s1gn1ng-t0k3ns"
AUTHENTICATION_JWT_ALGORITHM="HS256"
AUTHENTICATION_ACCESS_TOKEN_TTL=300
AUTHENTICATION_REFRESH_TOKEN_TTL=2592000
AUTHENTICATION_REFRESH_TOKEN_LENGTH=32
AUTHENTICATION_BCRYPT_ROUNDS=12


# ====================================================
# Logging Config
# ====================================================
LOGGING_LEVEL="INFO"
LOGGING_RECORD_FORMAT="%(asctime)s %(levelname)s %(name)s %(message)s"
LOGGING_PROPAGATE=false


# ====================================================
# Application API Config
# ====================================================
API_TITLE="Backend Core"

# Multi-line values are not supported by all parsers — keep on a single line.
API_DESCRIPTION="An educational project demonstrating how to build a backend server with Python, covering authentication, authorization, rate limiting, access logging and global error handling."
API_VERSION="0.1.0"
API_DOCS_URL="/docs"
API_REDOC_URL="/redoc"
API_OPENAPI_URL="/openapi.json"


# ====================================================
# Seed Config:
#   - SEED_ADMIN_EMAIL:     Email address for the initial admin account
#                           created during database seeding.
#   - SEED_ADMIN_PASSWORD:  Plaintext password for the initial admin account
#                           created during database seeding.
# ====================================================
SEED_ADMIN_EMAIL="admin@example.com"
SEED_ADMIN_PASSWORD="4dm1n-5up3r-53cr37-p455w0rd"


# ====================================================
# Uvicorn Config:
#   - UVICORN_HOST:         Network interface Uvicorn binds to.
#                           "0.0.0.0" accepts connections on all interfaces.
#   - UVICORN_PORT:         TCP port the server listens on.
#   - UVICORN_LOG_LEVEL:    Uvicorn's internal log verbosity. Independent from the application
#                           logger — controls only Uvicorn's own startup, shutdown, and access
#                           log messages.
# ====================================================
UVICORN_HOST="0.0.0.0"
UVICORN_PORT=8000
UVICORN_LOG_LEVEL="info"