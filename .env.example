# =============================================================================
# Server Config
# =============================================================================
SERVER_HOST="0.0.0.0"
SERVER_PORT=8000
SERVER_LOG_LEVEL="INFO"
SERVER_TITLE="Backend Core"
SERVER_DESCRIPTION="An educational project demonstrating how to build a backend server with Python, covering authentication, authorization, rate limiting, access logging and global error handling."
SERVER_VERSION="1.0.0"
SERVER_DOCS_URL="/docs"
SERVER_REDOC_URL="/redoc"
SERVER_OPENSERVER_URL="/openapi.json"
SERVER_DEEP_HEALTH_TIMEOUT=3.0


# ====================================================
# PostgreSQL Config
# ====================================================
POSTGRES_SUPERUSER_NAME="postgres_admin"
POSTGRES_SUPERUSER_PASSWORD="changeme"
POSTGRES_SYSTEM_DB_NAME="postgres_db"
POSTGRES_USER_NAME="postgres_user"
POSTGRES_USER_PASSWORD="changeme"
POSTGRES_USER_DB_NAME="user_db"
POSTGRES_HOST="127.0.0.1"
POSTGRES_INTERNAL_PORT=5432
POSTGRES_EXTERNAL_PORT=5432
POSTGRES_PORT=${POSTGRES_EXTERNAL_PORT}

POSTGRES_CONTAINER_NAME="postgres-server"


# ====================================================
# Redis Config
# ====================================================
REDIS_ADMIN_NAME="redis_admin"
REDIS_ADMIN_PASSWORD="changeme"
REDIS_USER_NAME="redis_user"
REDIS_USER_PASSWORD="changeme"
REDIS_HOST="127.0.0.1"
REDIS_INTERNAL_PORT=6379
REDIS_EXTERNAL_PORT=6379
REDIS_PORT=${REDIS_EXTERNAL_PORT}
REDIS_BLACKLIST_DB_INDEX=0
REDIS_REFRESH_TOKEN_DB_INDEX=1
REDIS_RATE_LIMIT_DB_INDEX=2

REDIS_CONTAINER_NAME="redis-server"


# ====================================================
# Tokens Config
# ====================================================
TOKENS_JWT_SECRET_KEY="changeme"
TOKENS_JWT_ALGORITHM="HS256"
TOKENS_ACCESS_TOKEN_TTL=300
TOKENS_REFRESH_TOKEN_TTL=2592000
TOKENS_REFRESH_TOKEN_LENGTH=32


# ====================================================
# Password Config
# ====================================================
PASSWORD_BCRYPT_ROUNDS=12


# ====================================================
# Rate Limit Config
# ====================================================
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60


# ====================================================
# Seed Config
# ====================================================
SEED_ADMIN_EMAIL="admin@example.com"
SEED_ADMIN_PASSWORD="changeme"